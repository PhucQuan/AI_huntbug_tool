# Gemini AI API Key (Required for AI features)
# Get free key at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# VirusTotal API Key (Optional - for passive subdomain discovery)
# Get free key at: https://www.virustotal.com/gui/join-us
VIRUSTOTAL_API_KEY=your_virustotal_api_key

# GitHub Personal Access Token (Optional - for github-subdomains tool)
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_personal_access_token

# Slack Webhook (Optional - for monitoring alerts)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Interactsh Server (Optional - for blind XSS/SSRF testing)
INTERACTSH_SERVER=https://your-interactsh-server.com
